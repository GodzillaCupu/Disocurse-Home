<div class="gc-homepage">

  {{! HERO BANNER }}
  <section
    class="gc-hero"
    style={{if
      this.heroBgUrl
      (concat
        "background-image: url('"
        this.heroBgUrl
        "'); background-color: #2563eb;"
      )
    }}
  >
    <div class="gc-hero__content">
      <h1 class="gc-hero__greeting">
        Selamat Datang{{#if this.isLoggedIn}}, {{this.displayName}}{{/if}}!
      </h1>
      <p class="gc-hero__cta-text">
        Apa kamu mau daftar menjadi Trainer di pelatihan Gasing tanggal 5-20
        Maret 2026?
      </p>
      <div class="gc-hero__cta-actions">
        <a href="/t/pendaftaran-trainer" class="gc-btn gc-btn--primary">
          Saya daftar!
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
          ><polyline points="6 9 12 15 18 9"></polyline></svg>
        </a>
        <span class="gc-hero__cta-count">50 guru mendaftar</span>
      </div>
    </div>
    <div class="gc-hero__mascots">
      {{! Use this.mascotCreativityUrl which resolves via __theme_upload_url }}
      {{#if this.mascotCreativityUrl}}
        <img
          src={{this.mascotCreativityUrl}}
          alt="Maskot Creativity"
          class="gc-hero__mascot-img gc-hero__mascot-creativity"
        />
      {{/if}}
      {{#if this.mascotLogicUrl}}
        <img
          src={{this.mascotLogicUrl}}
          alt="Maskot Logic"
          class="gc-hero__mascot-img gc-hero__mascot-logic"
        />
      {{/if}}
    </div>
  </section>

  {{! MAIN GRID }}
  <div class="gc-grid">

    {{! LEFT COLUMN }}
    <div class="gc-grid__left">

      {{! EKSKLUSIF KONTEN }}
      <section class="gc-card gc-exclusive">
        <div class="gc-exclusive__badge">Feb 2026</div>
        <h2 class="gc-card__title">Eksklusif Konten</h2>
        <p class="gc-exclusive__desc">Yuk belajar trik perkalian 2 digit, dan
          dapatkan soal-soal penjumlahan &lt;5.</p>
        <div class="gc-exclusive__illustration">
          <div class="gc-exclusive__img-placeholder">
            <span>Fun Math Trick for Kids</span>
          </div>
        </div>
      </section>

      {{! ADA APA DI KOMUNITAS }}
      <section class="gc-card gc-komunitas">
        <div class="gc-card__header">
          <h2 class="gc-card__title">Ada Apa di Komunitas Gasing?</h2>
          <a href="/latest" class="gc-card__more">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            ><polyline points="9 18 15 12 9 6"></polyline></svg>
          </a>
        </div>

        <div class="gc-tabs">
          <button
            class="gc-tabs__tab
              {{if (eq this.activeTab 'trending') 'gc-tabs__tab--active'}}"
            type="button"
            {{on "click" (fn this.switchTab "trending")}}
          >Trending</button>
          <button
            class="gc-tabs__tab
              {{if (eq this.activeTab 'latest') 'gc-tabs__tab--active'}}"
            type="button"
            {{on "click" (fn this.switchTab "latest")}}
          >Latest</button>
        </div>

        <div class="gc-topic-list">
          {{#if this.isLoading}}
            <div class="gc-loading">
              <div class="gc-loading__spinner"></div>
              <span>Memuat...</span>
            </div>
          {{else}}
            {{#each this.visibleTopics as |topic|}}
              <a href="/t/{{topic.slug}}/{{topic.id}}" class="gc-topic-item">
                <div class="gc-topic-item__avatar">
                  <div class="gc-topic-item__avatar-placeholder"></div>
                </div>
                <div class="gc-topic-item__content">
                  <h3 class="gc-topic-item__title">{{topic.title}}</h3>
                  <div class="gc-topic-item__meta">
                    <span class="gc-topic-item__age">
                      <svg
                        width="12"
                        height="12"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                      ><polyline points="15 10 20 15 15 20"></polyline><path
                          d="M4 4v7a4 4 0 0 0 4 4h12"
                        ></path></svg>
                      baru saja
                    </span>
                  </div>
                  <div class="gc-topic-item__stats">
                    {{#each topic.tags as |tag|}}
                      <span class="gc-tag">{{tag}}</span>
                    {{/each}}
                    <span class="gc-topic-item__likes">
                      <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                      ><path
                          d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
                        ></path></svg>
                      {{topic.likeCount}}
                    </span>
                    <span class="gc-topic-item__replies">
                      <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                      ><path
                          d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                        ></path></svg>
                      {{topic.replyCount}}
                    </span>
                  </div>
                </div>
              </a>
            {{/each}}
          {{/if}}
        </div>
      </section>

      {{! AYO BELAJAR GASING BERSAMA }}
      <section class="gc-card gc-belajar">
        <div class="gc-card__header">
          <h2 class="gc-card__title">Ayo Belajar Gasing Bersama!</h2>
          <a href="/c/gasing-library/" class="gc-card__more">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            ><polyline points="9 18 15 12 9 6"></polyline></svg>
          </a>
        </div>

        <span class="gc-belajar__label">Latest</span>

        <div class="gc-topic-list">
          {{#if this.isLoading}}
            <div class="gc-loading"><div
                class="gc-loading__spinner"
              ></div></div>
          {{else}}
            {{#each this.materiTopics as |topic|}}
              <a href="/t/{{topic.slug}}/{{topic.id}}" class="gc-topic-item">
                <div class="gc-topic-item__avatar">
                  <div class="gc-topic-item__avatar-placeholder"></div>
                </div>
                <div class="gc-topic-item__content">
                  <h3 class="gc-topic-item__title">{{topic.title}}</h3>
                  <div class="gc-topic-item__stats">
                    {{#each topic.tags as |tag|}}
                      <span class="gc-tag">{{tag}}</span>
                    {{/each}}
                    <span class="gc-topic-item__likes">
                      <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                      ><path
                          d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
                        ></path></svg>
                      {{topic.likeCount}}
                    </span>
                    <span class="gc-topic-item__replies">
                      <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                      ><path
                          d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                        ></path></svg>
                      {{topic.replyCount}}
                    </span>
                  </div>
                </div>
              </a>
            {{/each}}
          {{/if}}
        </div>
      </section>
    </div>

    {{! RIGHT COLUMN }}
    <div class="gc-grid__right">

      {{! VIRTUAL MEET-UP }}
      <section class="gc-card gc-meetup">
        <div class="gc-card__header">
          <h2 class="gc-card__title gc-card__title--italic">Virtual Meet-Up
            Selanjutnya</h2>
          <a href="/c/webinar" class="gc-card__more">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            ><polyline points="9 18 15 12 9 6"></polyline></svg>
          </a>
        </div>
        <div class="gc-meetup__cards">
          <div class="gc-meetup__event">
            <div class="gc-meetup__event-img"></div>
            <div class="gc-meetup__event-overlay">
              {{! button posisi top-right di atas card }}
              <a
                href="/t/qa-challenge"
                class="gc-btn gc-btn--success gc-btn--sm"
              >Saya ikut
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                ><polyline points="6 9 12 15 18 9"></polyline></svg>
              </a>
            </div>
            <div class="gc-meetup__event-info">
              <h3>Q&amp;A Challenge</h3>
              <span>Feb 12 · 17:00 - 18:00 WIB</span>
            </div>
          </div>
          <div class="gc-meetup__event">
            <div class="gc-meetup__event-img gc-meetup__event-img--alt"></div>
            <div class="gc-meetup__event-overlay">
              <a
                href="/t/townhall-feb-2026"
                class="gc-btn gc-btn--outline gc-btn--sm"
              >Daftar
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                ><polyline points="6 9 12 15 18 9"></polyline></svg>
              </a>
            </div>
            <div class="gc-meetup__event-info">
              <h3>Townhall Feb 2026</h3>
              <span>Feb 12 · 17:00 - 18:00 WIB</span>
            </div>
          </div>
        </div>
      </section>

      {{! GASING ACADEMY NEWS }}
      <section class="gc-card gc-news">
        <div class="gc-card__header">
          <h2 class="gc-card__title">Gasing Academy News</h2>
          <a href="/c/ga-updates" class="gc-card__more">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            ><polyline points="9 18 15 12 9 6"></polyline></svg>
          </a>
        </div>
        <div class="gc-news__list">
          {{#if this.isLoading}}
            {{! Skeleton loading }}
            <div class="gc-news__item gc-news__item--skeleton">
              <div class="gc-news__thumb gc-skeleton"></div>
              <div class="gc-news__content">
                <div
                  class="gc-skeleton gc-skeleton--text gc-skeleton--title"
                ></div>
                <div
                  class="gc-skeleton gc-skeleton--text gc-skeleton--meta"
                ></div>
              </div>
            </div>
            <div class="gc-news__item gc-news__item--skeleton">
              <div class="gc-news__thumb gc-skeleton"></div>
              <div class="gc-news__content">
                <div
                  class="gc-skeleton gc-skeleton--text gc-skeleton--title"
                ></div>
                <div
                  class="gc-skeleton gc-skeleton--text gc-skeleton--meta"
                ></div>
              </div>
            </div>
            <div class="gc-news__item gc-news__item--skeleton">
              <div class="gc-news__thumb gc-skeleton"></div>
              <div class="gc-news__content">
                <div
                  class="gc-skeleton gc-skeleton--text gc-skeleton--title"
                ></div>
                <div
                  class="gc-skeleton gc-skeleton--text gc-skeleton--meta"
                ></div>
              </div>
            </div>
          {{else if this.newsTopics.length}}
            {{#each this.newsTopics as |news|}}
              <a href="/t/{{news.slug}}/{{news.id}}" class="gc-news__item">
                {{! Thumbnail: gunakan image dari topic jika ada, fallback ke placeholder }}
                <div class="gc-news__thumb">
                  {{#if news.thumbnailUrl}}
                    <img
                      src={{news.thumbnailUrl}}
                      alt={{news.title}}
                      class="gc-news__thumb-img"
                      loading="lazy"
                    />
                  {{else if news.imageUrl}}
                    <img
                      src={{news.imageUrl}}
                      alt={{news.title}}
                      class="gc-news__thumb-img"
                      loading="lazy"
                    />
                  {{else}}
                    <div class="gc-news__thumb-placeholder">
                      <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        opacity="0.4"
                      ><rect x="3" y="3" width="18" height="18" rx="2" /><path
                          d="M3 9h18M9 21V9"
                        /></svg>
                    </div>
                  {{/if}}
                </div>
                <div class="gc-news__content">
                  <h3 class="gc-news__title">{{news.title}}</h3>
                  <div class="gc-news__meta">
                    {{#if news.formattedDate}}
                      <span class="gc-news__date">
                        <svg
                          width="11"
                          height="11"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                        ><rect x="3" y="4" width="18" height="18" rx="2" /><line
                            x1="16"
                            y1="2"
                            x2="16"
                            y2="6"
                          /><line x1="8" y1="2" x2="8" y2="6" /><line
                            x1="3"
                            y1="10"
                            x2="21"
                            y2="10"
                          /></svg>
                        {{news.formattedDate}}
                      </span>
                    {{/if}}
                    <span class="gc-news__readtime">
                      <svg
                        width="11"
                        height="11"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                      ><circle cx="12" cy="12" r="10" /><polyline
                          points="12 6 12 12 16 14"
                        /></svg>
                      {{news.readTime}}
                      menit baca
                    </span>
                  </div>
                  {{#if news.excerpt}}
                    <p class="gc-news__excerpt">{{news.excerpt}}</p>
                  {{/if}}
                </div>
              </a>
            {{/each}}
          {{else}}
            {{! Empty state }}
            <div class="gc-news__empty">
              <svg
                width="40"
                height="40"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                opacity="0.3"
              ><path
                  d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"
                /></svg>
              <p>Belum ada artikel terbaru.</p>
            </div>
          {{/if}}
        </div>
      </section>
      {{! MINI GAME }}
      <section class="gc-card gc-minigame">
        <div class="gc-minigame__illustration">
          {{#if this.mascotCommunicationUrl}}
            <img
              src={{this.mascotCommunicationUrl}}
              alt="Maskot Communication"
              class="gc-minigame__mascot"
            />
          {{/if}}
        </div>
        <div class="gc-minigame__content">
          <span class="gc-tag gc-tag--green">Computational Logic</span>
          <h2 class="gc-minigame__title">Katak dan Daun Teratai</h2>
          <p class="gc-minigame__desc">Perhatikan dan ingatlah urutan daun
            teratai yg muncul</p>
          <a href="/t/katak-dan-daun-teratai" class="gc-btn gc-btn--game">Ayo
            Main!</a>
        </div>
      </section>

    </div>
  </div>
</div>